---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlockRenderer from "@/components/BlockRenderer.astro";
import Form from "@/components/ui/Form.astro";
import { getEntry } from "astro:content";

const page = await getEntry("pages", "contact");
if (!page) throw new Error("Missing pages/contact.md");
const data = page.data;

const showForm = "show_form" in data ? data.show_form : true;

const metadata = {
  title: data.meta_title ?? data.title,
  description: data.description ?? undefined,
};

const blocks = "content_blocks" in data ? data.content_blocks ?? [] : [];
---

<BaseLayout {metadata}>
  <div
    data-editable="array"
    data-prop="content_blocks"
    data-component-key="_type"
  >
    {blocks.map((block, i) => (
      <>
        <BlockRenderer block={block} />
        {showForm && i === 0 && (
          <div class="reveal mx-auto max-w-xl bg-card border border-border rounded-3xl p-8 shadow-sm mb-12 md:mb-16">
            <Form />
          </div>
        )}
      </>
    ))}
  </div>
</BaseLayout>
