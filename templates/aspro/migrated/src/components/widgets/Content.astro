---
import WidgetWrapper from "./WidgetWrapper.astro";
import type { ImageMetadata } from "astro";
import { Picture } from "astro:assets";
import Headline from "@/components/ui/Headline.astro";
import type { ContentProps } from "@/types/types";

const {
  title,
  tagline,
  description = [],
  image,
  imageAlt = "",
  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render("bg"),
} = Astro.props as ContentProps;

const { container: containerClassProp = "", ...otherClasses } = classes;
const descriptionText = Array.isArray(description) ? description.join(" ") : description;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/**/*.{jpeg,jpg,png,gif,svg,webp,avif}",
  { eager: true },
);
const imageSrc = image
  ? (typeof image === "string" ? (images[image]?.default ?? image) : image)
  : undefined;
---

<WidgetWrapper
  id={id}
  isDark={isDark}
  containerClass={`max-w-4xl mx-auto px-4 ${containerClassProp}`}
  bg={bg}
  classes={otherClasses}
>
  <div class="text-center">
    <Headline
      title={title}
      subtitle={descriptionText}
      subtitleProp="description"
      tagline={tagline}
      classes={{
        container: "mb-8",
        title: "text-4xl md:text-6xl font-bold mb-2",
        subtitle: "text-lg text-muted-foreground",
      }}
    />
    {
      imageSrc && (
        <editable-image data-prop-src="image">
          {typeof imageSrc === "string" ? (
            <img
              src={imageSrc}
              alt={imageAlt}
              class="rounded-3xl shadow-2xl mx-auto mt-6 border border-border/50 aspect-video object-cover"
            />
          ) : (
            <Picture
              src={imageSrc}
              alt={imageAlt}
              widths={[400, 800, 1200]}
              class="rounded-3xl shadow-2xl mx-auto mt-6 border border-border/50 aspect-video object-cover"
            />
          )}
        </editable-image>
      )
    }
    <slot />
  </div>
</WidgetWrapper>
